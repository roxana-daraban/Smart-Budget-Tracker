replay_pid*
*.hprof

# Environment and local secrets (do not commit)
.env
.env.local
.env.*.local
backend/src/main/resources/application-local.properties
# Spring: fișierul real cu parole, JWT, chei API — copiază din templates/
backend/src/main/resources/application.properties
**/application-secrets.properties
*.secrets.properties
*.env.properties

# Key material
*.pem
*.p12
*.jks

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE / editor (root + generic)
.idea/
.vscode/
*.iml
*.ipr
*.iws

